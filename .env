DB_NAME=gov_spider_db
DB_USER=postgres
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432
LLM_URL=http://localhost:5000/v1/chat/completions
LLM_MODEL=qwen3-35b-awq
# Keep the embedder off the GPU so vLLM gets the full card (more KV cache =
# higher generation throughput). CPU embedding is ~30ms, off the critical path.
MEMORY_DEVICE=cpu

# Two-axis judge: enable qwen3 reasoning for deeper verdicts, with a large token
# budget so the reasoning + JSON is never truncated mid-way.
JUDGE_THINKING=true
JUDGE_MAX_TOKENS=8000
